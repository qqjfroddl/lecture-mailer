# 이 파일을 복사해 .env.local 로 만들고 값을 채운다.
# 절대 .env.local 은 git에 올리지 않는다.

# === Daum SMTP ===
SMTP_HOST=smtp.daum.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=ledhelper@daum.net
SMTP_PASS=다음_앱_비밀번호
SMTP_FROM_NAME=박재현
SMTP_FROM_EMAIL=ledhelper@daum.net

# === Google Sheets ===
# https://docs.google.com/spreadsheets/d/{이_부분}/edit
GOOGLE_SHEET_ID=시트_ID_입력

# Service Account JSON 의 client_email 값
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@xxx.iam.gserviceaccount.com

# Service Account JSON 의 private_key 값 (\n 이스케이프 그대로 한 줄로)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# === 관리자 인증 ===
ADMIN_PASSWORD=원하는_비밀번호
# openssl rand -hex 32 로 생성 권장
SESSION_SECRET=64자_랜덤_문자열

# === 배포 URL ===
# QR 코드에 들어가는 절대 URL. 배포 후 실제 도메인으로 교체.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
